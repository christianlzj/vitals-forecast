   ],
   "source": [
    "import json\n",
    "with open('matched_record_ids.json', 'w') as f:\n",
    "    json.dump(list(matched_record_ids), f)\n",
    "\n",
    "print(f\"Saved {len(matched_record_ids)} record IDs to matched_record_ids.json\")"
   ]
  },
